---
import { fetchVideos } from "../lib/youtube";
import Layout from "../layouts/Layout.astro";

const videos = await fetchVideos();
const [latest, ...rest] = videos;
---

<Layout title="YouTube — Marcelo Trylesinski">
  <p class="eyebrow">youtube</p>
  <h1 class="mt-2 font-display text-3xl font-bold tracking-tight">The FastAPI Expert channel</h1>
  <p class="mt-3 max-w-xl text-muted">
    Videos about programming, software development, and Python web internals.
    <a
      href="https://www.youtube.com/channel/UC91TdNbobUqT3d2CHcTkx8A"
      class="text-accent underline underline-offset-4">Subscribe on YouTube</a
    >.
  </p>

  {
    latest ? (
      <div class="mt-8">
        <iframe
          class="youtube-embed"
          src={`https://www.youtube.com/embed/${latest.videoId}`}
          title={latest.title}
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        />
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {rest.map((video) => (
            <iframe
              class="youtube-embed"
              src={`https://www.youtube.com/embed/${video.videoId}`}
              title={video.title}
              loading="lazy"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          ))}
        </div>
      </div>
    ) : (
      <p class="mt-8 font-mono text-sm text-muted">
        Video grid unavailable — visit the
        <a href="https://www.youtube.com/channel/UC91TdNbobUqT3d2CHcTkx8A" class="text-accent">
          channel directly
        </a>
        .
      </p>
    )
  }
</Layout>
