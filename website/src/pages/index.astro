---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 4);

const responseLines = [
  { text: "HTTP/1.1 200 OK", class: "text-ink font-medium", mobile: true },
  { text: "server: uvicorn", class: "text-muted", mobile: true },
  { text: "content-type: text/human; charset=utf-8", class: "text-muted", mobile: false },
  { text: "x-origin: Brazil 🇧🇷", class: "text-muted", mobile: false },
  { text: "x-location: Utrecht, Netherlands 🇳🇱", class: "text-muted", mobile: true },
];

const projects = [
  {
    name: "Starlette",
    role: "maintainer",
    description:
      "The little ASGI framework that shines — the foundation FastAPI is built on, downloaded hundreds of millions of times a month.",
    url: "https://www.starlette.io/",
  },
  {
    name: "Uvicorn",
    role: "maintainer",
    description: "The lightning-fast ASGI server. If you run an async Python web app, it probably serves it right now.",
    url: "https://www.uvicorn.org/",
  },
];
---

<Layout title="Marcelo Trylesinski">
  <!-- Hero: a raw HTTP exchange -->
  <section class="panel font-mono text-sm">
    <div class="border-b border-line px-5 py-3 text-muted sm:px-7">
      <span class="text-accent">GET</span> /marcelo HTTP/1.1<br />
      host: marcelotryle.com
    </div>
    <div class="px-5 py-5 sm:px-7 sm:py-6">
      {
        responseLines.map((line, index) => (
          <p class={`stream-line ${line.class} ${line.mobile ? "" : "hidden sm:block"}`} style={`--line-index: ${index}`}>
            {line.text}
          </p>
        ))
      }
      <div class="stream-line mt-6 flex items-center gap-5 sm:mt-8 sm:gap-7" style="--line-index: 6">
        <img
          src="https://avatars.githubusercontent.com/u/7353520?v=4"
          alt="Marcelo Trylesinski"
          width="112"
          height="112"
          class="h-20 w-20 rounded-full border border-line sm:h-28 sm:w-28"
        />
        <h1 class="font-display text-4xl font-bold tracking-tight sm:text-6xl">Marcelo Trylesinski</h1>
      </div>
      <p class="stream-line mt-5 max-w-2xl font-sans text-base text-muted sm:text-lg" style="--line-index: 7">
        I maintain the plumbing of Python's web:
        <a class="text-accent underline underline-offset-4" href="https://www.starlette.io/">Starlette</a> and
        <a class="text-accent underline underline-offset-4" href="https://www.uvicorn.org/">Uvicorn</a>. Also known as
        <a class="text-accent underline underline-offset-4" href="https://fastapi.tiangolo.com/fastapi-people/#experts"
          >The FastAPI Expert</a
        >.
      </p>
    </div>
  </section>

  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href="https://github.com/sponsors/Kludex"
      class="rounded-lg bg-accent-bright px-5 py-2.5 text-sm font-semibold text-white transition-transform hover:scale-[1.02]"
    >
      ❤️ Sponsor my work
    </a>
    <a
      href="/blog"
      class="rounded-lg px-5 py-2.5 text-sm font-semibold text-ink underline decoration-line underline-offset-4 transition-colors hover:text-accent"
    >
      Read the blog
    </a>
  </div>

  <!-- Projects -->
  <section class="mt-20">
    <h2 class="border-t border-line pt-6 font-display text-2xl font-bold tracking-tight sm:text-3xl">Work</h2>
    <div class="mt-8 grid gap-10 sm:grid-cols-2">
      {
        projects.map((project) => (
          <div>
            <h3 class="font-display text-2xl font-semibold">
              <a href={project.url} class="transition-colors hover:text-accent">
                {project.name}
              </a>
              <span class="ml-2 align-middle font-mono text-xs font-normal text-muted">{project.role}</span>
            </h3>
            <p class="mt-3 max-w-md text-base text-muted">{project.description}</p>
          </div>
        ))
      }
    </div>
    <p class="mt-10 text-base text-muted">
      Also the all-time top user on the FastAPI issue tracker — which earned me the name
      <a href="https://fastapi.tiangolo.com/fastapi-people/#experts" class="text-accent underline underline-offset-4"
        >“The FastAPI Expert”</a
      >.
    </p>
  </section>

  <!-- Latest posts -->
  <section class="mt-20">
    <div class="flex items-baseline justify-between border-t border-line pt-6">
      <h2 class="font-display text-2xl font-bold tracking-tight sm:text-3xl">Writing</h2>
      <a href="/blog" class="text-sm font-medium text-muted transition-colors hover:text-accent">All posts →</a>
    </div>
    <div class="mt-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</Layout>
