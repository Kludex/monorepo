---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const responseLines = [
  { text: "HTTP/1.1 200 OK", class: "text-ink font-medium" },
  { text: "server: uvicorn", class: "text-muted" },
  { text: "content-type: text/human; charset=utf-8", class: "text-muted" },
  { text: "x-origin: Brazil 🇧🇷", class: "text-muted" },
  { text: "x-location: Utrecht, Netherlands 🇳🇱", class: "text-muted" },
];

const projects = [
  {
    name: "starlette",
    role: "maintainer",
    description: "The little ASGI framework that shines. The foundation FastAPI is built on.",
    url: "https://www.starlette.io/",
  },
  {
    name: "uvicorn",
    role: "maintainer",
    description: "The lightning-fast ASGI server. It probably serves your app right now.",
    url: "https://www.uvicorn.org/",
  },
  {
    name: "fastapi",
    role: "expert",
    description: "Top user of all time on the issue tracker — hence “The FastAPI Expert”.",
    url: "https://fastapi.tiangolo.com/fastapi-people/#experts",
  },
];
---

<Layout title="Marcelo Trylesinski">
  <!-- Hero: a raw HTTP exchange -->
  <section class="rounded-lg border border-line bg-surface font-mono text-sm">
    <div class="border-b border-line px-5 py-3 text-muted">
      <span class="text-accent">GET</span> /marcelo HTTP/1.1<br />
      host: marcelotryle.com
    </div>
    <div class="px-5 py-4">
      {
        responseLines.map((line, index) => (
          <p class={`stream-line ${line.class}`} style={`--line-index: ${index}`}>
            {line.text}
          </p>
        ))
      }
      <div class="stream-line mt-6 flex flex-col gap-6 sm:flex-row sm:items-center" style="--line-index: 6">
        <img
          src="https://avatars.githubusercontent.com/u/7353520?v=4"
          alt="Marcelo Trylesinski"
          width="112"
          height="112"
          class="h-28 w-28 rounded-full border border-line"
        />
        <div class="font-sans">
          <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">Marcelo Trylesinski</h1>
          <p class="mt-3 max-w-xl text-muted">
            I maintain the plumbing of Python's web: <a class="text-accent underline underline-offset-4" href="https://www.starlette.io/">Starlette</a> and
            <a class="text-accent underline underline-offset-4" href="https://www.uvicorn.org/">Uvicorn</a>. Also known as
            <a class="text-accent underline underline-offset-4" href="https://fastapi.tiangolo.com/fastapi-people/#experts">the FastAPI Expert</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href="https://github.com/sponsors/Kludex"
      class="rounded-lg bg-accent-bright px-4 py-2 font-mono text-sm font-medium text-white transition-opacity hover:opacity-90"
    >
      ❤️ sponsor my work
    </a>
    <a
      href="/blog"
      class="rounded-lg border border-line bg-surface px-4 py-2 font-mono text-sm text-ink transition-colors hover:border-accent"
    >
      read the blog
    </a>
  </div>

  <!-- Projects -->
  <section class="mt-16">
    <p class="eyebrow">what i work on</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {
        projects.map((project) => (
          <a
            href={project.url}
            class="group rounded-lg border border-line bg-surface p-5 transition-colors hover:border-accent"
          >
            <p class="font-mono text-sm">
              <span class="font-medium group-hover:text-accent">{project.name}</span>
              <span class="text-muted"> · {project.role}</span>
            </p>
            <p class="mt-2 text-sm text-muted">{project.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Latest posts -->
  <section class="mt-16">
    <div class="flex items-baseline justify-between">
      <p class="eyebrow">latest posts</p>
      <a href="/blog" class="font-mono text-sm text-muted hover:text-accent">all posts →</a>
    </div>
    <div class="mt-4 grid gap-4">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</Layout>
