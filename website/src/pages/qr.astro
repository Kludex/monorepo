---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import QRCode from "qrcode";
import "../styles/global.css";

const qrSvg = await QRCode.toString("https://marcelotryle.com/links", {
  type: "svg",
  errorCorrectionLevel: "H",
  margin: 0,
  color: { dark: "#0e1118", light: "#ffffff" },
});
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Scan me — Marcelo Trylesinski</title>
  </head>
  <!--
    Laid out for an iOS lock screen: the top ~30% is left free for the clock,
    the bottom ~20% for notifications and the flashlight/camera buttons.
  -->
  <body class="starfield flex min-h-dvh flex-col items-center bg-paper px-8 text-ink">
    <div class="h-[30dvh] shrink-0"></div>
    <div class="text-center">
      <h1 class="font-display text-3xl font-bold tracking-tight">Marcelo Trylesinski</h1>
      <p class="mt-1 font-mono text-sm text-muted">The AI Expert</p>
    </div>
    <div class="qr mt-7 w-full max-w-60 rounded-3xl bg-white p-5 shadow-lg" set:html={qrSvg} />
    <p class="mt-5 font-mono text-sm text-muted">
      <span class="text-accent">GET</span> marcelotryle.com/links
    </p>
  </body>
</html>

<style>
  .qr :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
