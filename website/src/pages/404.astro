---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Marcelo Trylesinski">
  <p class="eyebrow"><span class="verb">GET</span> {"<anything>"}</p>
  <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">HTTP/1.1 404 Not Found</h1>
  <p class="mt-4 max-w-xl text-lg text-muted">
    This route isn't registered. Try the <a href="/" class="text-accent underline underline-offset-4">homepage</a> or
    the <a href="/blog" class="text-accent underline underline-offset-4">blog</a>.
  </p>
</Layout>
