---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog — Marcelo Trylesinski">
  <p class="eyebrow"><span class="verb">GET</span> /blog</p>
  <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">Notes from the ASGI trenches</h1>
  <p class="mt-4 max-w-xl text-lg text-muted">
    Deep dives on FastAPI, Starlette, Uvicorn, testing, and life as an open source maintainer.
  </p>
  <div class="mt-10 border-t border-line">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</Layout>
