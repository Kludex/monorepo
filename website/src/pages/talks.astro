---
import { talks } from "../data/talks";
import Layout from "../layouts/Layout.astro";

const years = [...new Set(talks.map((talk) => talk.year))].sort((a, b) => b - a);
---

<Layout title="Talks — Marcelo Trylesinski">
  <p class="eyebrow">talks</p>
  <h1 class="mt-2 font-display text-3xl font-bold tracking-tight">Conference talks</h1>
  <p class="mt-3 max-w-xl text-muted">
    Sharing what I know about Python, FastAPI, Starlette, ASGI, and open source maintenance — from PyCon keynotes to
    meetups.
  </p>

  {
    years.map((year) => (
      <section class="mt-12">
        <h2 class="font-mono text-sm text-muted">{year}</h2>
        <div class="mt-4 grid gap-6">
          {talks
            .filter((talk) => talk.year === year)
            .map((talk) => (
              <div class="rounded-lg border border-line bg-surface p-5">
                <p class="font-mono text-xs text-muted">
                  {talk.event}
                  {talk.keynote && <span class="ml-2 rounded bg-gold/15 px-1.5 py-0.5 text-gold">keynote</span>}
                </p>
                <h3 class="mt-1 font-display text-xl font-semibold">
                  <a href={talk.url} class="hover:text-accent">
                    {talk.title}
                  </a>
                </h3>
                {talk.youtubeId && (
                  <iframe
                    class="youtube-embed mt-4"
                    src={`https://www.youtube.com/embed/${talk.youtubeId}${talk.youtubeStart ? `?start=${talk.youtubeStart}` : ""}`}
                    title={`${talk.title} — ${talk.event} ${talk.year}`}
                    loading="lazy"
                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                )}
                {talk.slides && (
                  <p class="mt-3">
                    <a href={talk.slides} class="font-mono text-sm text-accent hover:underline">
                      view slides →
                    </a>
                  </p>
                )}
              </div>
            ))}
        </div>
      </section>
    ))
  }
</Layout>
